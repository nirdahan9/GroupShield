{
    "bot": {
        "name": "GroupShield",
        "version": "1.0.0"
    },
    "developer": {
        "jid": "YOUR_WHATSAPP_JID@s.whatsapp.net",
        "phone": "YOUR_PHONE_NUMBER"
    },
    "memory": {
        "maxMemoryMB": 400,
        "checkIntervalMs": 300000
    },
    "health": {
        "checkIntervalMs": 300000,
        "enableSelfHealing": true
    },
    "logging": {
        "level": "info",
        "console": true,
        "file": {
            "enabled": true,
            "generalLog": "logs/bot.log",
            "errorLog": "logs/error.log",
            "auditLog": "audit_log.txt"
        }
    },
    "database": {
        "file": "groupshield.db"
    },
    "backup": {
        "enabled": true,
        "schedule": "0 5 * * *",
        "keepBackups": 7,
        "backupDir": "backups"
    },
    "rateLimiting": {
        "enabled": true,
        "delayBetweenRemovalsMs": 2500,
        "maxRemovalsPerMinute": 15
    },
    "groq": {
        "apiKey": "",
        "model": "llama-3.1-8b-instant"
    },
    "warnings": {
        "resetAfterDays": 60
    },
    "scheduling": {
        "dailyRestart": "0 6 * * *",
        "statusMessages": "0 10,14,18,22 * * *",
        "groupNameRefreshIntervalMs": 300000,
        "warningsCleanup": "15 6 * * *",
        "unknownGroupExitEnabled": true,
        "unknownGroupExit": "30 6 * * *",
        "adminActionTimeoutHours": 4
    }
}